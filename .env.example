APP_NAME=auro
APP_ENV=dev
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
# Option A: use a full DSN (overrides split DB vars below)
DATABASE_URL=postgresql+psycopg://<db-user>:<db-password>@<db-host>:5432/<db-name>?sslmode=disable

# Option B: split vars (recommended for secrets management)
DB_HOST=<db-host>
DB_PORT=5432
DB_NAME=<db-name>
DB_USER=<db-user>
DB_PASSWORD=<db-password>
DB_SSL_MODE=disable

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
CLOUD_LLM_BASE_URL=
CLOUD_LLM_API_KEY=
CLOUD_LLM_MODEL=gpt-4.1-mini
WEB_BUILDER_PRIMARY_PROVIDER=ollama
WEB_BUILDER_FALLBACK_PROVIDER=cloud
WEB_BUILDER_FORCE_CLOUD_FOR_DESIGN=false
REQUEST_TIMEOUT_SECONDS=30
